{
  "functions": {
    "api/proxy.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/proxy" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
